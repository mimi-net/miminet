amqp_urls=amqp://user:password@rabbitmq/
rpc_urls=rpc://
celery_concurrency=4
result_queue_name=common-results-queue
exchange_name=default_exchange
RABBITMQ_DEFAULT_USER=user
RABBITMQ_DEFAULT_PASS=password
JWT_SECRET_KEY=a-string-secret-at-least-256-bits-long

# PostgreSQL для dev режима (локальный контейнер)
POSTGRES_DEFAULT_USER=postgres
POSTGRES_DEFAULT_PASSWORD=my_postgres
POSTGRES_DATABASE_NAME=miminet
POSTGRES_HOST=172.18.0.4

BASE_DOMAIN=local.tst
QUIZ_DOMAIN=quiz.${BASE_DOMAIN}
EXTERNAL_BASE_URL=/
QUIZ_URL=http://${QUIZ_DOMAIN}
ALLOWED_HOSTS=http://${BASE_DOMAIN},${QUIZ_URL}
# Время в часах
ACCESS_TOKEN_EXPIRES=3
REFRESH_TOKEN_EXPIRES=12

# Yandex Cloud PostgreSQL (для prod режима)
# Раскомментируйте и заполните при развертывании в продакшен:
# YANDEX_POSTGRES_HOST=your-yandex-cloud-host.mdb.yandexcloud.net
# YANDEX_POSTGRES_PORT=6432
# YANDEX_POSTGRES_USER=your_user
# YANDEX_POSTGRES_PASSWORD=your_password
# YANDEX_POSTGRES_DB=miminet
# YANDEX_POSTGRES_SSLMODE=verify-full

# Режим работы: dev (локальный PostgreSQL) или prod (Yandex Cloud PostgreSQL)
MODE=dev